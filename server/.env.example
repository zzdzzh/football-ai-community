PORT=3000
JWT_SECRET=your-dev-secret-change-in-production
DATABASE_PATH=./data/community.db

# 智谱 BigModel（OpenAI 兼容）
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=YOUR_API_KEY
AI_MODEL=glm-5.2
# glm-5 系列响应较慢，建议 >= 120000；轻量模型可用 glm-4-flash 并缩短超时
AI_TIMEOUT_MS=120000

INTERNAL_API_KEY=dev-internal-key

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# football-data.org v4（DATA_SOURCE=football-data 时使用）
FOOTBALL_DATA_API_KEY=your-football-data-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# 数据源：scraper（Python 爬虫）| football-data（API）
DATA_SOURCE=scraper
SCRAPER_PYTHON=python
SCRAPER_DIR=../scraper
SCRAPER_REQUEST_DELAY_SEC=1.5

# 可选：覆盖默认 cron（生产建议保持默认）
# MATCH_SYNC_CRON=*/30 * * * *
# MATCH_REPORT_CRON=*/5 * * * *
# PLAYER_SYNC_CRON=0 4 * * *

# 世界杯赛季年份（football-data.org 竞赛 WC 需 season 参数）
# FOOTBALL_DATA_WC_SEASON=2026

# Fan Agent 续写轮次超时（毫秒，默认 30000；首轮生成沿用 AI_TIMEOUT_MS / AgentProfile fan.timeout_ms）
# FAN_CONTINUE_TIMEOUT_MS=30000

# 内容过滤 blocklist 文件路径（可选，默认 ./config/content-blocklist.txt）
# CONTENT_MODERATION_BLOCKLIST=./config/content-blocklist.txt
