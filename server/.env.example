PORT=3001
JWT_SECRET=your-dev-secret-change-in-production
DATABASE_PATH=./data/community.db

# 智谱 BigModel（OpenAI 兼容）
# 自动内容（比赛战报、新闻 AI 摘要等 cron/job）
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=YOUR_API_KEY
AI_MODEL=glm-4.7-flash
# glm-5 系列响应较慢，建议 >= 120000；轻量 flash 模型可缩短超时
AI_TIMEOUT_MS=120000

# 交互式 AI（球员推荐、球迷对话、Stats/Tactical、关系叙事等用户触发）
# 未配置时回退到上方 AI_*；建议单独密钥 + 更强模型
# AI_INTERACTIVE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_INTERACTIVE_API_KEY=YOUR_INTERACTIVE_API_KEY
AI_INTERACTIVE_MODEL=glm-5.1
# AI_INTERACTIVE_TIMEOUT_MS=300000

# 内部 Job 鉴权（Header: x-internal-key）。复用于既有 match/player/news/report sync，
# 以及 006：POST /api/internal/player-identity-align（不新增独立密钥项）
INTERNAL_API_KEY=dev-internal-key

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# football-data.org v4（DATA_SOURCE=football-data 时使用）
FOOTBALL_DATA_API_KEY=your-football-data-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# 数据源：scraper（Python 爬虫）| football-data（API）
DATA_SOURCE=scraper
SCRAPER_PYTHON=python
# 可写绝对/相对路径；若不存在会自动尝试 scraper/.venv-soccerdata 下的 python
# SCRAPER_PYTHON=.venv-soccerdata/Scripts/python.exe
SCRAPER_DIR=../scraper
SCRAPER_REQUEST_DELAY_SEC=1.5

# 可选：覆盖默认 cron（默认每 30 分钟同步比赛；战报每 5 分钟）
# MATCH_SYNC_CRON=*/30 * * * *
# MATCH_REPORT_CRON=*/5 * * * *
# PLAYER_SYNC_CRON=0 4 * * *

# 世界杯赛季年份（football-data.org 竞赛 WC 需 season 参数）
# FOOTBALL_DATA_WC_SEASON=2026

# Fan Agent 续写轮次超时（毫秒，默认 30000；首轮生成沿用 AI_INTERACTIVE_TIMEOUT_MS / AI_TIMEOUT_MS / AgentProfile fan.timeout_ms）
# FAN_CONTINUE_TIMEOUT_MS=30000

# 内容过滤 blocklist 文件路径（可选，默认 ./config/content-blocklist.txt）
# CONTENT_MODERATION_BLOCKLIST=./config/content-blocklist.txt

# 球员关系分析 / 履历同步（005）
# 履历缓存 TTL（天，默认 7）
CAREER_SYNC_TTL_DAYS=7
# 间接路径最大跳数（默认 6）
RELATIONSHIP_MAX_HOPS=6
# 单次外部同步超时毫秒（默认 20000）
# Transfermarkt profile 常需 30–60s；过短会爬虫超时导致分析无法落库
CAREER_SYNC_TIMEOUT_MS=60000
# 遇 Transfermarkt 人机验证时，自动拉起 scripts/refresh_tm_cookies.py --auto（有头浏览器，仍需人工点验证）
# 无图形界面的服务器请设为 0
CAREER_AUTO_REFRESH_TM_COOKIES=1
# 自动刷新 Cookie 最长等待秒数（默认 300）
# CAREER_TM_COOKIE_REFRESH_TIMEOUT_SEC=300

# 007 关系叙事使用 agentId=relationship，与其它 Agent 共用 AI_RATE_LIMIT_*（不新增第二套限流）
# 仅真实调用模型的 POST 生成计入限流；同结论版本缓存命中 / GET 复用不消耗配额
# AI_RATE_LIMIT_MAX=10
# AI_RATE_LIMIT_WINDOW_MS=60000

# 关系叙事 Agent（007，agentId=relationship）
# 超时优先读 agent_profiles.relationship.timeout_ms（迁移种子建议 45000）；
# 模型/密钥走 AI_INTERACTIVE_*（未配置则回退 AI_*）
# 外置 Prompt：server/prompts/relationship-narrative.md
# RELATIONSHIP_NARRATIVE_TIMEOUT_MS=45000
