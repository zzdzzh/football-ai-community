          "weight": 20,
          "blocking": true,
          "sort_order": 29
        },
        {
          "criterion_key": "S1-C30",
          "description": "宪法是否规定修订须 PR + 影响分析？",
          "weight": 20,
          "blocking": true,
          "sort_order": 30
        }
      ]
    },
